{
  "name": "@kalisio/kfs-mcp",
  "version": "1.0.0",
  "description": "MCP server for interacting with the Kalisio Features Service (OGC API Features)",
  "type": "module",
  "main": "server.js",
  "bin": {
    "kfs-mcp": "server.js"
  },
  "scripts": {
    "start": "node server.js",
    "mocha": "mocha --exit",
    "mocha:integration": "NODE_CONFIG_DIR=../test/config/ mocha --exit --timeout 30000 test/integration.test.js",
    "test": "npm run mocha"
  },
  "mocha": {
    "spec": "test/server.test.js",
    "timeout": 5000
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "mocha": "^10.8.2"
  },
  "engines": {
    "node": ">=18"
  }
}
